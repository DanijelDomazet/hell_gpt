    "version": "0.2.0",
    "configurations": [
        {
            "name": "app.py default model",
            "type": "debugpy",
            "request": "launch",
            "program": "sgpt/app.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            //"args": ["--chat", "dev2", "--token_limit", "1500", "What are the folders in my home folder"]
            "args": [
                "--chat",
                "dev2",
                "--token_limit",
                "1000",
                //"What are the folders in my tmp folder?"
                "Whats 4+3?"
            ]
            //"args": ["--chat", "dev2", "What are the planets in solar system?"]
            //"args": ["--install-functions"]
        },
        {
            "name": "app.py O3 model",
            "type": "debugpy",
            "request": "launch",
            "program": "sgpt/app.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            //"args": ["--chat", "dev2", "--token_limit", "1500", "What are the folders in my home folder"]
            "args": [
                "--chat",
                "devo3",
                "--model",
                "o3",
                "--temperature",
                "1",
                "What are the folders in my tmp folder?"
            ]
            //"args": ["--chat", "dev2", "What are the planets in solar system?"]
            //"args": ["--install-functions"]
        },
        {
            "name": "app.py show chats",
            "type": "debugpy",
            "request": "launch",
            "program": "sgpt/app.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "args": [
                "--show-chat",
                "nrm_o3",
                "--qa",
                "20"
            ]
        },
    ]
}